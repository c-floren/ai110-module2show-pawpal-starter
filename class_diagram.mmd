classDiagram
    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +str special_needs
    }

    class Owner {
        +str name
        +float available_hours_per_day
    }

    class Task {
        +str name
        +int duration
        +int priority
        +str time_preference
        +str frequency
        +str assigned_pet
        +str notes
    }

    class DailySchedule {
        +date date
        +list scheduled_tasks
        +list warnings
        +add_task(task, start_time)
        +get_total_duration() int
        +is_overbooked() bool
    }

    class Scheduler {
        +Owner owner
        +list pets
        +list tasks
        +generate() DailySchedule
        +order_by_priority(tasks) list
        +validate(schedule) list
    }

    Scheduler --> Owner : uses
    Scheduler "1" --> "*" Pet : uses
    Scheduler "1" --> "*" Task : manages
    Scheduler --> DailySchedule : produces
    DailySchedule "1" --> "*" Task : contains
